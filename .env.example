# Copy to .env and fill in. Get a free NVIDIA key at https://build.nvidia.com
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
# Spotify playback control (play_music / control_playback tools). Create a free app
# at https://developer.spotify.com/dashboard and add the redirect URI
# http://127.0.0.1:8090/api/spotify/callback — then connect in Settings.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Phase 2+
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
